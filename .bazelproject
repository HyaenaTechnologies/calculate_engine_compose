additional_languages:
  android
  c
  dart
  java
  kotlin

android_min_sdk: 34

android_sdk_platform: "android-34"

bazel_binary: /usr/bin/kotlin/bazel_build/bazel

directories:
  .

java_language_level: 17

shard_sync: true

targets:
  app:App

test_sources:
  app/test/kotlin/*

workspace_type: android