additional_languages:
  android
  c
  dart
  java
  kotlin

android_min_sdk: 34

android_sdk_platform: "UpsideDownCake"

bazel_binary: usr/bin/kotlin/bazel_build

directories:
  android
  desktop
  ios
  lib
  test
  web

java_language_level: 17

shard_sync: true

targets:
  //android:Android
  //desktop:Desktop
  //ios:IOS
  //lib:Lib
  //test:Test
  //web:Web

test_sources:
  test/src/main/kotlin/*.kt
  test/src/main/kotlin/**/*.kt

workspace_type: Android