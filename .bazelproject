additional_languages:
  android
  c
  dart
  java
  kotlin

android_min_sdk: 34

android_sdk_platform: "UpsideDownCake"

bazel_binary: usr/bin/kotlin/bazel_build

directories:
  android/src/main/kotlin
  desktop/src/main/kotlin
  ios/src/main/kotlin
  lib/src/main/kotlin
  test/src/main/kotlin
  web/src/main/kotlin

java_language_level: 17

shard_sync: true

targets:
  android/src/main/kotlin:Android
  desktop/src/main/kotlin:Desktop
  ios/src/main/kotlin:IOS
  lib/src/main/kotlin:Library
  test/src/main/kotlin:Test
  web/src/main/kotlin:Web

test_sources:
  test/src/main/kotlin/*.kt
  test/src/main/kotlin/**/*.kt

workspace_type: Android